# Copy this file to .env and fill in your keys. .env is gitignored.

# Enables the Fetch panel's "Suggest from image (Claude)" feature.
ANTHROPIC_API_KEY=

# Optional: Openverse API credentials — the photo-heavy fetch source.
# Register (returns client_id/secret; then verify the email Openverse sends):
#   curl -X POST https://api.openverse.org/v1/auth_tokens/register/ \
#     -H "Content-Type: application/json" \
#     -d '{"name":"collajit","description":"personal collage app","email":"you@example.com"}'
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=

# Pexels — free, high-volume photo API. Get a key at https://www.pexels.com/api/
PEXELS_API_KEY=
